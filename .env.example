# Persistent operational database (required for production, bookings, MCP tokens, and command-center history)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_me

# Admin authentication (use ADMIN_USERS_JSON with pbkdf2 password hashes in production)
ADMIN_SESSION_SECRET=replace_with_a_long_random_secret
ADMIN_USERS_JSON=[]

# Square merchant connection. Set the environment explicitly so live tokens are never sent to sandbox.
SQUARE_ENVIRONMENT=production
SQUARE_ACCESS_TOKEN=replace_me
SQUARE_LOCATION_ID=replace_me
SQUARE_APPLICATION_ID=replace_me
SQUARE_WEBHOOK_SIGNATURE_KEY=replace_me
SQUARE_CHECKOUT_SURFACE=web-payments

# Midway assistant (Responses API)
OPENAI_API_KEY=replace_me
OPENAI_MODEL=gpt-5.6-terra
OPENAI_REASONING_EFFORT=low

# Encrypts OpenAI and vendor MCP credentials saved from the command center.
PROVIDER_CREDENTIALS_ENCRYPTION_KEY=replace_with_a_long_random_secret

# Optional local HarborHub MCP process. Credentials stay in the server environment
# and are never returned by the command center or passed through the assistant.
# HARBOR_MCP_SERVER_PATH=/absolute/path/to/harborhub-mcp/dist/index.js
# HARBOR_EMAIL=replace_me
# HARBOR_PASSWORD=replace_me

# Scheduled sync authentication
MIDWAY_CRON_SECRET=replace_with_a_long_random_secret

# Optional environment-backed vendor MCP bearer tokens can be named freely,
# then referenced by name in Connections. Tokens pasted in the UI are encrypted instead.
# HARBOR_MCP_TOKEN=replace_me
