{
  "version": 2,
  "crons": [
    {
      "path": "/api/cron/instagram-refresh",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/sales-history",
      "schedule": "30 9 * * *"
    }
  ],
  "builds": [
    {
      "src": "api/[...path].js",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/[...path].js"
    },
    {
      "src": "/manage",
      "dest": "/manage.html"
    },
    {
      "src": "/rv-park",
      "dest": "/rv-park.html"
    },
    {
      "src": "/tent-camping",
      "dest": "/tent-camping.html"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
