{
  "name": "interstellar-aurora",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 3000",
    "api": "node api-server.js",
    "api:test": "MIDWAY_ALLOW_MEMORY_STORE=true ADMIN_USERS_JSON='[{\"id\":\"test-owner\",\"email\":\"admin@midway.local\",\"name\":\"Test Owner\",\"role\":\"owner\",\"passwordHash\":\"midway-dev-owner\"}]' node api-server.js",
    "api:admin": "ADMIN_USERS_JSON='[{\"id\":\"local-admin\",\"email\":\"admin@midway.local\",\"name\":\"Local Admin\",\"role\":\"owner\",\"passwordHash\":\"midway-dev-owner\"}]' node api-server.js",
    "test": "node --test",
    "smoke:visual": "node --test test/visual-smoke.test.js",
    "smoke:browser:availability": "node --test test/browser-visual-availability.test.js",
    "smoke": "npm test && npm run build",
    "build": "vite build",
    "preview": "vite preview"
  },
  "devDependencies": {
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@slack/bolt": "^4.6.0",
    "@supabase/supabase-js": "^2.95.3",
    "axios": "^1.13.5",
    "cors": "^2.8.6",
    "dotenv": "^17.2.4",
    "express": "^5.2.1",
    "harborhub-mcp": "file:vendor/harborhub-mcp",
    "openai": "^6.21.0",
    "pdf-lib": "^1.17.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "square": "^44.0.0"
  }
}
